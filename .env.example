OPENAI_API_KEY="voc-00000000000000000000000000000000abcd.12345678"
OPENAI_API_BASE=https://openai.vocareum.com/v1
# ChromaDB — when running via docker-compose, point to the container
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# When running locally (outside Docker), use:
# CHROMA_HOST=localhost

# Embedding model — two options:
#   OpenAI (paid, higher quality): text-embedding-3-small
#   HuggingFace (free, runs locally): BAAI/bge-small-en-v1.5
EMBED_MODEL=text-embedding-3-small
EMBED_PROVIDER=openai

# LLM model
LLM_MODEL=gpt-4o
